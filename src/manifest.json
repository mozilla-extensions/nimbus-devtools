{
  "manifest_version": 2,
  "name": "nimbus-devtools",
  "version": "0.4.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "nimbus-devtools@mozilla.com",
      "strict_min_version": "150.0.a1",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": ["mozillaAddons"],
  "browser_action": {
    "default_title": "Nimbus Developer Tools",
    "browser_style": true
  },
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": [
        "https://experimenter.services.mozilla.com/*",
        "https://stage.experimenter.nonprod.webservices.mozgcp.net/*"
      ],
      "js": ["experimenter.js"]
    }
  ],
  "experiment_apis": {
    "messagingSystem": {
      "schema": "apis/messagingSystem.json",
      "parent": {
        "scopes": ["addon_parent"],
        "script": "apis/messagingSystem.js",
        "paths": [["experiments", "messagingSystem"]]
      }
    },
    "nimbus": {
      "schema": "apis/nimbus.json",
      "parent": {
        "scopes": ["addon_parent"],
        "script": "apis/nimbus.js",
        "paths": [["experiments", "nimbus"]]
      }
    }
  },
  "icons": {
    "64": "./icons/64.png",
    "32": "./icons/32.png"
  }
}
